# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Cloudinary (for photos)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Cloudflare R2 (for videos) — client-safe vars only
VITE_R2_PUBLIC_URL=https://your-bucket.r2.dev
VITE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
VITE_R2_BUCKET_NAME=your-bucket-name

# R2 server-side (for Vercel API functions) — keep these secret!
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=your-bucket-name
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_PUBLIC_URL=https://your-bucket.r2.dev
CF_API_TOKEN=your-cloudflare-api-token
